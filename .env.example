# Translation Configuration
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: Translator and reviewer names for metadata
TRANSLATOR_NAME=AI Assistant
REVIEWER_NAME=Your Name

# Local development — copy .dev.vars.example to .dev.vars for wrangler dev
# Production/preview secrets — set via Cloudflare Workers dashboard or `wrangler secret put`
# TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, STUDIO_GITHUB_CLIENT_ID, STUDIO_GITHUB_CLIENT_SECRET

# GitHub Actions (environment: Cloudflare)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here